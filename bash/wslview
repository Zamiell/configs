#!/bin/bash

# This is a shim for the "wslview" program, which was deprecated:
# https://github.com/wslutilities/wslu/discussions/329
# Since other tools like "npm login" look for a binary called "wslview", we create a shim to achieve
# similar functionality.

set -euo pipefail # Exit on errors and undefined variables.

if [[ $# -eq 0 ]]; then
  echo "Error: URL or path is required. Usage: ${0##*/} <url-or-path>..." >&2
  exit 1
fi

for target in "$@"; do
  if [[ -e "$target" ]]; then
    target=$(wslpath --windows "$target")
  fi

  WSLVIEW_TARGET="$target" \
    WSLENV="WSLVIEW_TARGET${WSLENV:+:$WSLENV}" \
    powershell.exe -NoProfile -NonInteractive -Command "\$target = [Environment]::GetEnvironmentVariable('WSLVIEW_TARGET'); if ([string]::IsNullOrWhiteSpace(\$target)) { exit 1 }; Start-Process -FilePath \$target" > /dev/null 2>&1
done
